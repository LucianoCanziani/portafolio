---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
import FeaturedCard from "../components/FeaturedCard.astro";

const posts = Object.values(import.meta.glob("./proyectos/*.{md,mdx}", { eager: true })).sort(
  (a, b) =>
    new Date(b.frontmatter.pubDate).valueOf() -
    new Date(a.frontmatter.pubDate).valueOf()
);

const postsWork = Object.values(import.meta.glob("./projects-work/*.{md,mdx}", { eager: true })).sort(
  (a, b) =>
    new Date(b.frontmatter.pubDate).valueOf() -
    new Date(a.frontmatter.pubDate).valueOf()
);

const featuredProjects = [...posts, ...postsWork]
  .filter(post => post.frontmatter.featured)
  .sort((a, b) => {
    // Force e-presis to be first
    if (a.url?.includes('e-presis')) return -1;
    if (b.url?.includes('e-presis')) return 1;
    return new Date(b.frontmatter.pubDate).valueOf() - new Date(a.frontmatter.pubDate).valueOf();
  })
  .slice(0, 4);

const funProjects = [...posts, ...postsWork]
  .filter(post => post.frontmatter.fun)
  .sort((a, b) => {
    if (a.url?.includes('do-it-for-her')) return -1;
    if (b.url?.includes('do-it-for-her')) return 1;
    return 0;
  });
---

<BaseLayout
  title="Luciano Canziani Portfolio"
  description=`Hello! My name is Luciano and I am a Web Developer. I have experience in
      developing projects of international impact, collaborating with
      professionals from various nations.`
>
  <div class="pb-12 mt-5">
    <h1 class="text-5xl font-bold portafolio-title">Luciano Canziani</h1>
    <h2 class="text-3xl py-3 font-bold">Full-Stack Web Developer</h2>
    <div class="py-2">
      <p class="text-lg mb-5">
        Hello! My name is Luciano and I am a Web Developer. I have experience in
        developing projects of international impact, collaborating with
        professionals from various nations.
      </p>
      <p class="text-lg">
        I am looking for projects that I am excited to be a part of and
        challenges that will help me grow.
      </p>
    </div>
    <div class="mt-8">
      <a
        class="btn bg-blue-50 text-black hover:bg-blue-100 border-none shadow-md transition-transform hover:-translate-y-0.5"
        href="https://www.linkedin.com/in/luciano-canziani/"
        target="_blank"
      >
        Let's Connect!</a
      >
    </div>
  </div>

  <div class="mb-14">
    <div class="flex items-center justify-between mb-8">
      <div class="text-4xl font-black text-white flex items-center gap-4">
        Featured Experience
        <div class="h-1 w-20 bg-blue-500 rounded-full hidden sm:block"></div>
      </div>
      <div class="text-sm font-bold text-blue-400 uppercase tracking-widest hidden sm:block">
        Professional Highlights
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {
        featuredProjects.map((post) => (
          <FeaturedCard
            title={post.frontmatter.title}
            img={post.frontmatter.heroImage}
            desc={post.frontmatter.description}
            url={post.url}
            stack={post.frontmatter.stack}
            target="_self"
          />
        ))
      }
    </div>
  </div>

  <div class="mb-14">
    <div class="flex items-center gap-3 mb-8">
      <div class="text-3xl font-bold text-white">Fun Projects</div>
      <span class="text-2xl">🎮</span>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {
        funProjects.map((post) => (
          <FeaturedCard
            title={post.frontmatter.title}
            img={post.frontmatter.heroImage}
            desc={post.frontmatter.description}
            url={post.url}
            stack={post.frontmatter.stack}
            target="_self"
          />
        ))
      }
    </div>
  </div>

  <div>
    <div class="text-3xl w-full font-bold mb-2">
      Work Projects {"</>"}
    </div>
  </div>

  {
    postsWork.map((post) => (
      <>
        <HorizontalCard
          title={post.frontmatter.title}
          img={post.frontmatter.heroImage}
          desc={post.frontmatter.description}
          url={post.url}
          stack={post.frontmatter.stack}
          date={post.frontmatter.pubDate}
          target="_self"
        />
        <div class="divider my-0 " />
      </>
    ))
  }
  <div class="divider my-0 mb_31"></div>
  <div>
    <div class="text-3xl w-full font-bold mb-2">
      Personal Projects {"</>"}
    </div>
  </div>

  {
    posts.map((post) => (
      <>
        <HorizontalCard
          title={post.frontmatter.title}
          img={post.frontmatter.heroImage}
          desc={post.frontmatter.description}
          url={post.url}
          stack={post.frontmatter.stack}
          date={post.frontmatter.pubDate}
          target="_self"
        />
        <div class="divider my-0" />
      </>
    ))
  }
</BaseLayout>
