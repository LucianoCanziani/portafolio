---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
import FeaturedCard from "../components/FeaturedCard.astro";
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { SITE_TITLE, SITE_DESCRIPTION } from '../config';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const posts = Object.values(import.meta.glob("./proyectos/*.{md,mdx}", { eager: true })).sort(
  (a, b) =>
    new Date(b.frontmatter.pubDate).valueOf() -
    new Date(a.frontmatter.pubDate).valueOf()
);

const postsWork = Object.values(import.meta.glob("./projects-work/*.{md,mdx}", { eager: true })).sort(
  (a, b) =>
    new Date(b.frontmatter.pubDate).valueOf() -
    new Date(a.frontmatter.pubDate).valueOf()
);

const featuredProjects = [...posts, ...postsWork]
  .filter(post => post.frontmatter.featured)
  .sort((a, b) => {
    if (a.url?.includes('e-presis')) return -1;
    if (b.url?.includes('e-presis')) return 1;
    return new Date(b.frontmatter.pubDate).valueOf() - new Date(a.frontmatter.pubDate).valueOf();
  })
  .slice(0, 4);

const funProjects = [...posts, ...postsWork]
  .filter(post => post.frontmatter.fun)
  .sort((a, b) => {
    if (a.url?.includes('do-it-for-her')) return -1;
    if (b.url?.includes('do-it-for-her')) return 1;
    return 0;
  });
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION} lang={lang}>
  <div class="pb-12 mt-5">
    <h1 class="text-4xl sm:text-5xl font-bold">Luciano Canziani</h1>
    <h2 class="text-2xl sm:text-3xl py-3 font-bold">Full-Stack Web Developer</h2>
    <div class="py-2">
      <p class="text-lg mb-5">{t('index.intro.p1')}</p>
      <p class="text-lg">{t('index.intro.p2')}</p>
    </div>
    <div class="mt-8">
      <a
        class="btn bg-blue-50 text-black hover:bg-blue-100 border-none shadow-md transition-transform hover:-translate-y-0.5"
        href="https://www.linkedin.com/in/luciano-canziani/"
        target="_blank"
      >{t('index.cta')}</a>
    </div>
  </div>

  <div class="mb-8 md:mb-14">
    <div class="flex items-center justify-between mb-6">
      <div class="text-2xl md:text-3xl font-bold text-white flex items-center gap-4 w-full sm:w-auto">
        {t('index.featured.title')}
        <div class="h-1 flex-grow sm:flex-none sm:w-20 bg-blue-500 rounded-full"></div>
      </div>
      <div class="text-sm font-bold text-blue-400 uppercase tracking-widest hidden sm:block">
        {t('index.featured.subtitle')}
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-8">
      {
        featuredProjects.map((post) => (
          <FeaturedCard
            title={post.frontmatter.title}
            img={post.frontmatter.heroImage}
            desc={post.frontmatter.description}
            url={post.url}
            tagline={post.frontmatter.tagline}
            lang={lang}
            target="_self"
          />
        ))
      }
    </div>
  </div>

  <div class="mb-14">
    <div class="flex items-center gap-3 mb-6">
      <div class="text-2xl md:text-3xl font-bold text-white">{t('index.fun.title')}</div>
      <span class="text-2xl">🎮</span>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-8">
      {
        funProjects.map((post) => (
          <FeaturedCard
            title={post.frontmatter.title}
            img={post.frontmatter.heroImage}
            desc={post.frontmatter.description}
            url={post.url}
            tagline={post.frontmatter.tagline}
            badge={t('card.fun.badge')}
            lang={lang}
            target="_self"
          />
        ))
      }
    </div>
  </div>

  <div class="mb-6">
    <div class="text-2xl md:text-3xl w-full font-bold">
      {t('index.work.title')} {"</>"}
    </div>
  </div>

  {
    postsWork.map((post) => (
      <>
        <HorizontalCard
          title={post.frontmatter.title}
          img={post.frontmatter.heroImage}
          desc={post.frontmatter.description}
          url={post.url}
          stack={post.frontmatter.stack}
          date={post.frontmatter.pubDate}
          target="_self"
        />
        <div class="divider my-2" />
      </>
    ))
  }
  <div class="divider my-2 mb-3"></div>
  <div class="mb-6">
    <div class="text-2xl md:text-3xl w-full font-bold">
      {t('index.personal.title')} {"</>"}
    </div>
  </div>

  {
    posts.map((post) => (
      <>
        <HorizontalCard
          title={post.frontmatter.title}
          img={post.frontmatter.heroImage}
          desc={post.frontmatter.description}
          url={post.url}
          stack={post.frontmatter.stack}
          date={post.frontmatter.pubDate}
          target="_self"
        />
        <div class="divider my-2" />
      </>
    ))
  }
</BaseLayout>
