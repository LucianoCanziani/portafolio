---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import SideBar from "../components/SideBar.astro";

import { SITE_TITLE, SITE_DESCRIPTION } from "../config";
import type { Lang } from "../i18n/ui";
import { getAlternateLangPath } from "../i18n/utils";

const {
  image,
  title = SITE_TITLE,
  description = SITE_DESCRIPTION,
  lang = 'es' as Lang,
} = Astro.props;

const alternatePath = getAlternateLangPath(Astro.url.pathname, lang);
---

<!DOCTYPE html>
<html lang={lang} data-theme="dark">
  <head>
    <script is:inline>
      if (
        window.location.pathname === '/' &&
        !sessionStorage.getItem('lang-chosen') &&
        navigator.language?.startsWith('en')
      ) {
        window.location.replace('/en');
      }
    </script>
    <BaseHead title={title} description={description} image={image} />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700&display=swap" rel="stylesheet">
    <style>
      body {
        font-family: 'Inter', sans-serif;
      }
    </style>
  </head>
  <body>
    <div class="bg-gradient-to-br from-gray-900 via-[#1a1c2c] to-gray-900 text-gray-100 drawer drawer-mobile min-h-screen">
      <input id="my-drawer" type="checkbox" class="drawer-toggle" />
      <div class="drawer-content flex flex-col">
        <Header lang={lang} alternatePath={alternatePath} />
        <div class="w-full">
          <main class="p-6 pt-4 md:pt-10 max-w-[900px] w-full mx-auto lazy_loading">
            <slot />
          </main>
        </div>
        <Footer />
      </div>
      <SideBar lang={lang} currentPath={Astro.url.pathname} />
    </div>
  </body>
</html>
