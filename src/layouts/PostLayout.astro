---
import BaseLayout from "./BaseLayout.astro";
import { getLangFromUrl, useTranslations } from '../i18n/utils';

export interface Props {
  content: {
    title: string;
    description: string;
    pubDate?: string;
    updatedDate?: string;
    heroImage?: string;
    altImage?: string;
    gitHub?: string;
    deploy?: string;
    stack?: string;
  };
}

const {
  content: {
    title,
    description,
    pubDate,
    updatedDate,
    heroImage,
    altImage,
    gitHub,
    deploy,
    stack,
  },
} = Astro.props;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<BaseLayout
  title={title}
  description={description}
  image={heroImage}
  lang={lang}
>
  <main class="md:flex md:justify-center">
    <article class="prose prose-lg max-w-[750px] prose-img:mx-auto">
      <a
        href={lang === 'en' ? '/en' : '/'}
        class="not-prose inline-flex items-center gap-2 text-sm text-gray-400 hover:text-blue-400 active:text-blue-400 transition-colors mb-4"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        {lang === 'es' ? 'Volver al inicio' : 'Back to home'}
      </a>
      {
        heroImage && (
          <img
            src={heroImage}
            alt={altImage}
            class="lazy_loading w-full mb-6"
            style="border-radius: 5px;"
          />
        )
      }
      <h1 class="title my-2 text-4xl font-bold">{title}</h1>
      <span>Luciano Canziani -</span><time> {pubDate}</time>
      <div class="icon-cont">
        {
          gitHub ? (
            <a
              href={gitHub}
              target="_blank"
              class="mx-3 icon-item"
              aria-label={t('post.github')}
            >
              <img src="/github.svg" alt={t('post.github.alt')} />
              <span>{t('post.github')}</span>
            </a>
          ) : null
        }
        {
          deploy ? (
            <a href={deploy} target="_blank" class="mx-3 icon-item" aria-label={t('post.deploy')}>
              <img src="/website.png" alt={t('post.deploy.alt')} />
              <span>{t('post.deploy')}</span>
            </a>
          ) : null
        }
      </div>
      <div class="divider my-2"></div>
      <slot />
    </article>
  </main>
</BaseLayout>
