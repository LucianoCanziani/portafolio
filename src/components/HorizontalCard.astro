---
import StackBadge from "./cv/StackBadge";

const {
  title,
  img,
  desc,
  url,
  badge,
  tags,
  stack,
  date,
  target = "_blank",
} = Astro.props;
---

<div
  class="horizontal_card rounded-2xl bg-white/5 border border-white/10 backdrop-blur-md hover:shadow-2xl hover:shadow-blue-500/10 hover:border-blue-500/30 transition-all duration-300 ease-out hover:-translate-y-1 group"
>
  <a href={url} target={target} class="flex flex-col md:flex-row gap-5 p-5 h-full">
    <div class="shrink-0 overflow-hidden rounded-xl w-full md:w-44 aspect-video md:aspect-auto md:h-28">
      <img src={img} alt={title} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
    </div>
    <div class="flex flex-col gap-2 justify-center">
      <h3 class="text-xl font-bold text-gray-100 group-hover:text-blue-400 transition-colors">
        {title}
        {badge && <div class="badge badge-secondary mx-2">{badge}</div>}
      </h3>
      <div class="stack-cont">
        <StackBadge client:only="react" stack={stack} />
      </div>
      <p class="text-sm text-neutral-400 line-clamp-2">{desc}</p>
    </div>
  </a>
</div>
