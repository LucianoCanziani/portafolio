---
import StackBadge from "./cv/StackBadge";

const {
  title,
  img,
  desc,
  url,
  badge,
  tags,
  stack,
  date,
  target = "_blank",
} = Astro.props;
---

<div
  class="horizontal_card rounded-2xl bg-white/5 border border-white/10 backdrop-blur-md hover:shadow-2xl hover:shadow-blue-500/10 hover:border-blue-500/30 transition-all duration-300 ease-out hover:-translate-y-1 group"
>
  <a href={url} target={target} class="block h-full">
    <div class="hero-content flex-col md:flex-row p-6 gap-6">
      <div class="overflow-hidden rounded-xl shrink-0">
        <img src={img} alt={title} class="post-img w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
      </div>
      <div class="grow w-full flex flex-col gap-2">
        <h3 class="text-2xl font-bold text-gray-100 group-hover:text-blue-400 transition-colors">
          {title}
          {badge && <div class="badge badge-secondary mx-2">{badge}</div>}
        </h3>
        <!-- {date} -->
        <div class="stack-cont">
          <StackBadge client:only="react" stack={stack} />
        </div>
        <p class="py-1 text-1xl">{desc}</p>
        <div class="card-actions justify-end">
          {
            tags &&
              tags.map((tag) => <div class="badge badge-outline">{tag}</div>)
          }
        </div>
      </div>
    </div>
  </a>
</div>
