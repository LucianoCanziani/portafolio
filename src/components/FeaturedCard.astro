---
import StackBadge from "./cv/StackBadge";
import { useTranslations } from '../i18n/utils';
import type { Lang } from '../i18n/ui';

const {
  title,
  img,
  desc,
  url,
  stack,
  lang = 'es' as Lang,
  target = "_blank",
} = Astro.props;

const t = useTranslations(lang);
---

<div class="featured-card group relative overflow-hidden rounded-3xl bg-neutral-900 border border-white/5 transition-all duration-500 hover:border-blue-500/50 hover:shadow-[0_0_50px_-12px_rgba(59,130,246,0.3)]">
  <a href={url} target={target} class="block h-full">
    <div class="aspect-[16/10] overflow-hidden relative">
      <!-- Gradient Overlay -->
      <div class="absolute inset-0 bg-gradient-to-t from-neutral-950 via-transparent to-transparent opacity-60 z-10"></div>

      <!-- Image -->
      <img
        src={img}
        alt={title}
        class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-110"
      />

      <!-- Floating Badge -->
      <div class="absolute top-4 right-4 z-20">
        <span class="px-3 py-1 rounded-full bg-blue-500/10 backdrop-blur-md border border-blue-500/30 text-blue-400 text-xs font-bold tracking-wider uppercase">
          {t('card.featured.badge')}
        </span>
      </div>
    </div>

    <!-- Content -->
    <div class="p-8 relative z-20 -mt-12">
      <div class="bg-neutral-900/80 backdrop-blur-xl rounded-2xl p-6 border border-white/10 shadow-xl group-hover:border-blue-500/20 transition-colors">
        <div class="mb-4">
           <StackBadge client:only="react" stack={stack} />
        </div>

        <h3 class="text-2xl font-black text-white mb-3 group-hover:text-blue-400 transition-colors">
          {title}
        </h3>

        <p class="text-neutral-400 text-sm leading-relaxed line-clamp-3 mb-6">
          {desc}
        </p>

        <div class="flex items-center text-blue-400 font-bold text-sm group-hover:gap-2 transition-all">
          {t('card.featured.cta')}
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-1 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </div>
      </div>
    </div>
  </a>
</div>

<style>
  .featured-card {
    perspective: 1000px;
  }
</style>
