---
import { useTranslations } from '../i18n/utils';
import type { Lang } from '../i18n/ui';

const {
  title,
  img,
  url,
  tagline,
  badge,
  lang = 'es' as Lang,
  target = "_blank",
} = Astro.props;

const t = useTranslations(lang);
const badgeLabel = badge ?? t('card.featured.badge');
---

<div class="featured-card group relative overflow-hidden rounded-2xl bg-neutral-900 border border-white/5 transition-all duration-500 hover:border-blue-500/50 hover:shadow-[0_0_50px_-12px_rgba(59,130,246,0.3)]">
  <a href={url} target={target} class="flex flex-col h-full">
    <div class="aspect-video overflow-hidden relative">
      <!-- Image -->
      <img
        src={img}
        alt={title}
        class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-105"
      />

      <!-- Floating Badge -->
      <div class="absolute top-4 right-4 z-20">
        <span class="px-3 py-1 rounded-full bg-neutral-950/60 backdrop-blur-md border border-white/10 text-blue-400 text-[10px] font-bold tracking-wider uppercase">
          {badgeLabel}
        </span>
      </div>
    </div>

    <!-- Content -->
    <div class="p-6 flex flex-col flex-1">
      <h3 class="text-xl font-bold text-white mb-3 group-hover:text-blue-400 transition-colors">
        {title}
      </h3>

      {tagline && (
        <p class="text-sm text-neutral-400 italic mb-4">{tagline}</p>
      )}

      <div class="flex items-center text-blue-400 font-bold text-sm group-hover:gap-2 transition-all mt-auto">
        {t('card.featured.cta')}
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-1 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </div>
    </div>
  </a>
</div>

<style>
  .featured-card {
    transition: transform 0.3s ease-out, box-shadow 0.3s ease-out;
  }
  .featured-card:hover {
    transform: translateY(-4px);
  }
</style>
